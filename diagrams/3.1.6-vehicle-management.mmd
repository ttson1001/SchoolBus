%% =============================================================================
%% 3.1.6 Vehicle Management (Buses) — specification + flow
%% Route UI: /vehicles | API: BusController — Search, Create, Update, Delete
%% BusCreateDto: LicensePlate, Capacity, Status, BusNumber, ImageUrl, Color, BusType
%% Note: Gán tài xế trên form có thể map sang BusAssignment / lịch chạy (Bus không có DriverId trong entity hiện tại).
%% BR06: Khi xe đủ học sinh kỳ tới — available capacity 0 — chặn mua gói trỏ vào xe (cần logic Order/Package).
%% =============================================================================

flowchart TD
    subgraph trigger["Trigger"]
        T["Sidebar → Vehicle Management /vehicles"]
    end

    subgraph grid["Interface"]
        G["Grid: Status Active/Inactive, Capacity column"]
        T --> G
    end

    subgraph add["Add vehicle"]
        A1["Enter license plate e.g. 51H-123.45"]
        A2["Enter Capacity number e.g. 16"]
        A3["Managing Driver — dropdown Drivers searchable"]
        A4["Submit"]
        G --> A1
        A1 --> A2
        A2 --> A3
        A3 --> A4
    end

    subgraph validate["Client validation"]
        V{"Capacity equals -1?"}
        A4 --> V
        V -->|Yes| E["Red border on capacity — no API call"]
        V -->|No| S["POST /api/Bus/Create"]
    end

    subgraph result["Response"]
        S --> OK["200 — Bus created successfully"]
        OK --> BR["BR06: orders check remaining seats vs bus capacity"]
    end

    style E fill:#ffeeee
