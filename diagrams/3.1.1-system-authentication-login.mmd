%% =============================================================================
%% 3.1.1 System Authentication (Login) — specification + Mermaid flow
%% Product: FaceRide Admin (example URL: admin.faceride.com)
%% Backend: POST login API returns JWT Bearer Token (see BE Account/Login).
%% =============================================================================
%%
%% Function trigger:
%%   When the user opens the browser and types the Admin page URL. If the browser
%%   does not have a valid Cookie/Token, the system automatically redirects to /login.
%%
%% Actors / roles: Admin, Staff
%% Purpose: Internal security; only correctly provisioned accounts access data.
%%
%% Interface (Card, centered):
%%   FaceRide Logo, Email field, Password field, blue Login button,
%%   language switch EN/VI at page corner.
%%
%% Data processing: POST to server to obtain JWT Bearer Token.
%%
%% Screen layout: (wireframe / mockup to be inserted by design team)
%% //////////////////////////////////////////////////////////////////////////////
%%
%% Business rule: BR01 — No self-service Registration on this screen; accounts
%%   are provisioned internally (aligns with backend: no public Register on Account API).
%% =============================================================================

flowchart TD
    subgraph trigger["Function trigger"]
        A["User navigates to Admin URL<br/>(e.g. admin.faceride.com)"]
        B{"Browser has valid<br/>Cookie / Token?"}
        A --> B
        B -->|No| R["Auto redirect to /login"]
        B -->|Yes| OK["Enter app / Dashboard<br/>(not shown in detail here)"]
    end

    subgraph loginPage["1. Display form"]
        R --> L1["Show Login page"]
        L1 --> UI["Card UI: Logo, Email, Password,<br/>Login button, EN/VI switch"]
    end

    subgraph input["2. Data input"]
        UI --> E["User enters Email"]
        E --> P["User enters Password<br/>(masked as dots)"]
    end

    subgraph action["3. Execution"]
        P --> C["User clicks blue Login button"]
        C --> SP["Button shows loading spinner<br/>(network in progress)"]
    end

    subgraph process["4. System processing"]
        SP --> POST["POST credentials to server<br/>→ obtain JWT Bearer Token"]
    end

    subgraph response["5. Response"]
        POST --> S{"Result?"}
        S -->|Success| T["Green Toast (MSG20):<br/>Login successful"]
        T --> NAV["Smooth redirect to Dashboard"]
        NAV --> SB["Sidebar visible — session active"]

        S -->|Fail: wrong email/password| AL["Red Alert above Email field:<br/>Login failed. Please check email and password."]
        AL --> SP2["Spinner stops — user can fix input"]
        SP2 --> UI
    end

    subgraph rules["Business rule"]
        BR["BR01: No Registration on this screen;<br/>accounts provisioned internally"]
    end

    style BR fill:#f9f9f9,stroke:#666,stroke-dasharray: 5 5
