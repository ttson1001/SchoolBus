%% 3.2.15 Top-up Wallet — sequence
%% POST /api/Wallet/CreatePayOsTopUpLink WalletPayOsCreateDto
%% BR68: Positive whole-number amount — validate on client and server

sequenceDiagram
    autonumber
    actor Guardian as Guardian
    participant App as Mobile App
    participant WC as WalletController
    participant WS as WalletService
    participant PayOS as PayOS API
    participant Repo as Wallet Payment
    participant DB as SQL Server

    Guardian->>App: Enter amount → Proceed with PayOS
    App->>WC: POST /api/Wallet/CreatePayOsTopUpLink
    WC->>WS: CreatePayOsTopUpLinkAsync
    WS->>PayOS: Create payment link
    PayOS-->>WS: checkout URL
    WS->>Repo: Persist pending record if applicable
    WS-->>WC: link DTO
    WC-->>App: 200 OK
    App->>App: Open WebView / VietQR
    Guardian->>PayOS: Complete bank payment
