%% Sequence diagram — Login (layered architecture)
%% Order: Actor > UI > Controller > Service > Repository > Database
%% Code refs: AccountController.Login, AccountService.LoginAsync, IRepository User, BeContext SQL Server

sequenceDiagram
    autonumber
    actor Actor as User
    participant UI as UI (Admin SPA)
    participant Ctl as Controller (AccountController)
    participant Svc as Service (AccountService)
    participant Repo as Repository (IRepository User)
    participant DB as Database (SQL Server BeContext)

    Actor->>UI: Enter email, password, click Login
    UI->>UI: Show loading spinner on button
    UI->>Ctl: POST /api/Account/Login (LoginDto)

    Ctl->>Svc: LoginAsync(dto)

    Svc->>Repo: Get().Include(Role).FirstOrDefaultAsync(email)
    Repo->>DB: EF query Users (+ Role join)
    DB-->>Repo: Result set
    Repo-->>Svc: User + Role or null

    alt User not found
        Svc-->>Ctl: throw KeyNotFoundException
        Ctl-->>UI: 400 Bad Request
        UI-->>Actor: Alert above email field
    else Account disabled
        Svc-->>Ctl: throw (disabled)
        Ctl-->>UI: 400 Bad Request
        UI-->>Actor: Error message
    else Wrong password
        Svc-->>Ctl: throw (invalid password)
        Ctl-->>UI: 400 Bad Request
        UI-->>Actor: Error message
    else Credentials OK
        Note over Svc: BCrypt.Verify(password, PasswordHash)
        opt Device token changed
            Svc->>Repo: Update(user), SaveChangesAsync()
            Repo->>DB: UPDATE Users (DeviceToken)
            DB-->>Repo: OK
            Repo-->>Svc: Done
        end
        Note over Svc: IJwtService.GenerateToken(user) issues JWT
        Svc-->>Ctl: LoginReponseDto { Token }
        Ctl-->>UI: 200 OK + token
        UI->>UI: Store token, stop spinner
        UI-->>Actor: Toast success, navigate to Dashboard
    end
