%% 3.2.18 Track Bus Location — sequence
%% GET /api/BusTracking/GetLatest/{busId} — polling (or SignalR later)
%% busId from assignment / schedule
%% BR75: Only during active operational window — enforce in backend or app

sequenceDiagram
    autonumber
    actor Guardian as Guardian
    participant App as Mobile App
    participant BTC as BusTrackingController
    participant BTS as BusTrackingService
    participant Repo as IRepository BusTracking
    participant DB as SQL Server

    Guardian->>App: Open Tracking (active trip)
    loop Poll GPS
        App->>BTC: GET /api/BusTracking/GetLatest/{busId}
        BTC->>BTS: GetLatestAsync
        BTS->>Repo: Latest coordinate
        Repo->>DB: SELECT
        BTS-->>BTC: lat, lng, timestamp
        BTC-->>App: 200 OK
        App->>App: Draw map marker + ETA (client)
    end
