%% 3.2.9 Search Packages — sequence
%% GET /api/Package/Active or Search with keyword (partial name)
%% BR37: Partial match on package name

sequenceDiagram
    autonumber
    actor Guardian as Guardian
    participant App as Mobile App
    participant PC as PackageController
    participant PS as PackageService
    participant Repo as IRepository Package
    participant DB as SQL Server

    Guardian->>App: Type keyword e.g. monthly
    opt Local filter
        App->>App: Filter cached list on device
    end
    opt API search
        App->>PC: GET /api/Package/Active?keyword=monthly
        PC->>PS: GetActivePackagesAsync
        PS->>Repo: WHERE name contains keyword
        Repo->>DB: SELECT
        PC-->>App: 200 OK
    end
    App->>Guardian: Filtered package cards
