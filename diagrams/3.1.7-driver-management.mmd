%% =============================================================================
%% 3.1.7 Driver Management — specification + flow
%% Route UI: /drivers | API: POST /api/User/CreateDriver (DriverCreateDto)
%% DTO: Email, Password, FullName, Phone, DriverLicenseNumber, Class, ExpiryDate
%% BR07: License expiry phải sau ngày hiện tại — UserService validate khi tạo driver.
%% Avatar upload: có thể dùng Upload + cập nhật profile nếu FE lưu URL (DTO hiện không có Avatar field).
%% =============================================================================

flowchart TD
    subgraph trigger["Trigger"]
        T["Sidebar → Driver Management /drivers"]
    end

    subgraph create["Create Driver"]
        C1["Click Create Driver"]
        C2["Form: Full Name, Email, Password"]
        C3["License number text, class"]
        C4["Expiration — Datepicker only future BR07"]
        C5["Optional: Avatar upload"]
        C6["Click Create"]
        T --> C1
        C1 --> C2
        C2 --> C3
        C3 --> C4
        C4 --> C5
        C5 --> C6
    end

    subgraph api["API"]
        C6 --> P["POST /api/User/CreateDriver"]
        P --> R{"200 OK?"}
        R -->|Yes| K["Celebratory Toast"]
        R -->|No| X["Show error"]
    end

    subgraph br["BR07"]
        BR["Expiry date must be greater than today — past dates disabled in picker"]
    end

    C4 -.-> BR
