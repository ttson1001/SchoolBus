@host = http://localhost:5031

### Search packages
GET {{host}}/api/Package/Search?keyword=&page=1&pageSize=10
Accept: application/json

### Get package by id
GET {{host}}/api/Package/Get/1
Accept: application/json

### Create package
POST {{host}}/api/Package/Create
Content-Type: application/json

{
  "name": "Goi Tieu Chuan 30 Ngay",
  "price": 350000,
  "durationDays": 30,
  "description": "Goi dua don hoc sinh trong 30 ngay",
  "status": "ACTIVE",
  "type": "MONTHLY",
  "imageUrl": "https://example.com/package-standard.png"
}

### Update package
PUT {{host}}/api/Package/Update/1
Content-Type: application/json

{
  "name": "Goi Tieu Chuan 30 Ngay - Cap Nhat",
  "price": 390000,
  "durationDays": 30,
  "description": "Goi da cap nhat de test update",
  "status": "ACTIVE",
  "type": "MONTHLY",
  "imageUrl": "https://example.com/package-standard-updated.png"
}

### Delete package
DELETE {{host}}/api/Package/Delete/1
Accept: application/json
